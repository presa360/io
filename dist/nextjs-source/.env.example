# --- AI provider (OpenAI-compatible Chat Completions API) ---
# Любой провайдер с совместимым /chat/completions эндпоинтом
# (OpenAI, OpenRouter, Together, локальный gateway и т.д.)

# Ключ API. НЕ коммитьте реальный ключ.
AI_API_KEY=

# Идентификатор модели, например: gpt-4o-mini, gpt-4.1, llama-3.1-70b и т.д.
AI_MODEL=gpt-4o-mini

# Базовый URL API (по умолчанию OpenAI). Меняйте под своего провайдера.
AI_BASE_URL=https://api.openai.com/v1
